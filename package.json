    "seller:setup": "node src/backend/scripts/setupSellerDashboard.cjs",
    "seller:address-column": "node src/backend/scripts/ensureSellerAddressColumn.cjs",
    "seller:marketplace-setup": "node src/backend/scripts/ensureSellerMarketplaceColumns.cjs",
    "db:ensure-schema": "node src/backend/scripts/ensureSellerMarketplaceColumns.cjs",
    "chat:ensure-schema": "node src/backend/scripts/ensureChatSchema.cjs"
  },
  "dependencies": {
    "@easypost/api": "^8.8.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "binpackingjs": "^4.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^12.40.0",
    "geocodio-library-node": "^1.15.0",
    "google-auth-library": "^10.6.2",
    "graphile-worker": "^0.16.6",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "konsta": "^5.1.0",
    "lucide-react": "^1.16.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.8",
    "pg": "^8.20.0",
    "pocketbase": "^0.27.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-easy-crop": "^5.5.7",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "stripe": "^22.1.1",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "nodemon": "^3.0.1",
    "vite": "^8.0.16"
  },
  "allowScripts": {
    "bcrypt@6.0.0": true,
    "sharp@0.34.5": true
  }
}
