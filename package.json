{
  "name": "movie_thing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "NODE_OPTIONS=--disable-warning=DEP0205 vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:server": "node src/backend/server.cjs",
    "start:worker": "node src/backend/worker/runWorker.cjs",
